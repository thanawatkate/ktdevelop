{
  "name": "ktdevelop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3007": "next dev --port 3007",
    "build": "next build",
    "start": "next start",
    "start:3007": "next start --port 3007",
    "prepare": "node -e \"console.log('Skipping automatic DB migration in prepare. Run npm run db:setup manually.')\"",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:create": "node src/scripts/db-create.js",
    "db:migrate": "dotenv -e .env -- db-migrate up --env dev",
    "db:migrate:down": "dotenv -e .env -- db-migrate down --env dev",
    "db:migrate:status": "dotenv -e .env -- db-migrate up --count 0 --env dev",
    "db:setup": "npm run db:create && npm run db:migrate",
    "db:migrate:create": "db-migrate create",
    "db:migrate:prod": "db-migrate up --env production"
  },
  "dependencies": {
    "mysql2": "^3.15.2",
    "next": "^15.3.0",
    "next-intl": "^4.9.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.21",
    "c8": "^11.0.0",
    "db-migrate": "^0.11.14",
    "db-migrate-mysql": "^3.0.0",
    "dotenv-cli": "^11.0.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  }
}
