# Refined .gitignore for ktdevelop

# Node modules
node_modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Next.js / build outputs
.next/
frontend/.next/
out/
build/
dist/

# Local env files
.env
.env.local
.env.*.local

# Editor directories
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# Caches
.cache/
.parcel-cache/
.vercel/
.vercel/output/

# Coverage
coverage/

# Uploads / generated files
public/uploads/

# Misc
*.tgz
*.pem
